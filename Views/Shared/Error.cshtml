@{
    ViewData["Title"] = "Error";
}

<div class="error-card">
    <div class="error-icon-wrap">
        <i class="bi bi-exclamation-octagon-fill"></i>
    </div>
    <h3 style="font-size:22px;font-weight:800;margin-bottom:8px;">Something went wrong</h3>
    <p class="text-muted" style="font-size:14px;margin-bottom:24px;">
        An unexpected error occurred. Please return to your dashboard and try again.
    </p>
    <div class="d-flex gap-2 justify-content-center flex-wrap">
        <a asp-controller="Tasks" asp-action="Dashboard" class="btn btn-primary">
            <i class="bi bi-house-door"></i> Go to Dashboard
        </a>
        <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
            <i class="bi bi-arrow-left"></i> Go Back
        </button>
    </div>
</div>
