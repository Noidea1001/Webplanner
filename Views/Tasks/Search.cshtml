@model TaskSearchViewModel
@{
    ViewData["Title"] = "Search Tasks";
}

<div class="d-flex flex-column gap-4">

    <!-- Search Form Card -->
    <div class="search-card">
        <div class="uppercase-tracking mb-3" style="font-size:10px;">
            <i class="bi bi-funnel-fill me-1"></i> Search & Filter
        </div>
        <form asp-action="Search" method="get">
            <div class="row align-items-end" style="--bs-gutter-x:12px;--bs-gutter-y:12px;">

                <!-- Keyword -->
                <div class="col-12 col-md-5">
                    <label class="form-label">Keyword</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="Query" value="@Model.Query" class="form-control"
                               placeholder="Search title or description…" />
                    </div>
                </div>

                    <!-- Priority --> 
                <div class="col-12 col-sm-6 col-md-3"> 
                    <label class="form-label">Priority</label> 
                    <select name="Priority" class="form-select"> 
                        <option value="">Any Priority</option> 
                        @foreach (var p in Enum.GetValues<TaskPriority>()) 
                        { 
                            <option value="@p" selected="@(Model.Priority == p)">@p</option> 
                        } 
                    </select> 
                </div>

                <!-- Hashtag -->
                <div class="col-12 col-sm-6 col-md-3">
                    <label class="form-label">Hashtag</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-hash"></i></span>
                        <input type="text" name="Hashtag" value="@Model.Hashtag" class="form-control" placeholder="work" />
                    </div>
                </div>

                <!-- Submit -->
                <div class="col-12 col-md-1" style="display:flex;gap:6px;">
                    <button type="submit" class="btn btn-primary w-100" title="Search" style="min-width:44px;">
                        <i class="bi bi-search"></i>
                    </button>
                    @if (!string.IsNullOrWhiteSpace(Model.Query) || Model.Priority.HasValue || !string.IsNullOrWhiteSpace(Model.Hashtag))
                    {
                        <a asp-action="Search" class="btn btn-outline-secondary" title="Clear filters" style="flex-shrink:0;">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>

    <!-- Results -->
    @if (Model.Results.Any())
    {
        <div>
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="uppercase-tracking">Results</span>
                <span class="badge bg-light">@Model.Results.Count found</span>
            </div>

            <div class="task-list">
                @foreach (var task in Model.Results)
                {
                    <div class="task-list-row task-row @task.Priority @(task.IsCompleted ? "completed" : "")">
                        <span class="priority-dot @task.Priority"></span>

                        <div style="flex:1;min-width:0;">
                            <a asp-action="Details" asp-route-id="@task.Id" class="task-title">@task.Title</a>
                            @if (task.HashtagList.Any())
                            {
                                <div class="d-flex gap-1 flex-wrap mt-1">
                                    @foreach (var tag in task.HashtagList)
                                    {
                                        <span class="hashtag-pill">#@tag</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="task-meta">
                            @if (task.EndDate.HasValue)
                            {
                                bool isOver = !task.IsCompleted && task.EndDate.Value.Date < DateTime.Today;
                                <span class="badge @(isOver ? "bg-danger" : "bg-light")">
                                    <i class="bi bi-calendar-event"></i> @task.EndDate.Value.ToString("MMM dd")
                                </span>
                            }
                            <span class="priority-pill @task.Priority">@task.Priority</span>
                        </div>

                        <div style="display:flex;gap:4px;flex-shrink:0;">
                            <a asp-action="Edit"   asp-route-id="@task.Id" class="btn btn-sm btn-icon btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@task.Id" class="btn btn-sm btn-icon btn-outline-secondary" title="Delete"><i class="bi bi-trash"></i></a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.Query) || Model.Priority.HasValue || !string.IsNullOrWhiteSpace(Model.Hashtag))
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-search"></i></div>
            <h4>No matches found</h4>
            <p>Try adjusting your keyword, priority filter, or hashtag. Check for typos.</p>
            <a asp-action="Search" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-lg"></i> Clear Filters
            </a>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-search"></i></div>
            <h4>Search your tasks</h4>
            <p>Enter a keyword, choose a priority, or type a hashtag to find tasks.</p>
        </div>
    }
</div>
