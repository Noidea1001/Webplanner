@model TaskFormViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<div class="row justify-content-center">
    <div class="col-12" style="max-width:720px;">
        <div class="form-card">
            <!-- Header -->
            <div class="form-card-header">
                <div class="d-flex align-items-center gap-3 mb-1">
                    <div style="width:38px;height:38px;border-radius:10px;background:var(--color-primary-light);display:flex;align-items:center;justify-content:center;color:var(--color-primary);font-size:18px;">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <div>
                        <h3>Edit task</h3>
                        <p>Update the fields below and save your changes.</p>
                    </div>
                </div>
            </div>

            <!-- Body -->
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <div class="form-card-body">
                    @await Html.PartialAsync("_TaskFormFields", Model)
                </div>

                <!-- Footer -->
                <div class="form-card-footer">
                    <div class="form-check m-0" style="display:flex;align-items:center;gap:8px;">
                        <input asp-for="IsCompleted" class="form-check-input" id="isCompletedEdit" />
                        <label for="isCompletedEdit" class="form-label m-0" style="font-size:13.5px;color:var(--color-text-muted);">
                            Mark as completed
                        </label>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
